graph TD
    subgraph email["Email Authentication"]
        SPF["<b>SPF</b><br/><i>RFC 7208</i>"]:::blue
        DKIM["<b>DKIM</b><br/><i>RFC 6376</i>"]:::blue
        DMARC["<b>DMARC</b><br/><i>RFC 7489</i>"]:::blue
    end

    subgraph transport["Transport Security"]
        DANE["<b>DANE/TLSA</b><br/><i>RFC 6698</i>"]:::green
        DNSSEC["<b>DNSSEC</b><br/><i>RFC 4033–4035</i>"]:::green
        BIMI["<b>BIMI</b><br/><i>BIMI Working Group</i>"]:::green
    end

    subgraph policy["Policy &amp; Reporting"]
