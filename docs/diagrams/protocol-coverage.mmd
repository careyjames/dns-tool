        TLSRPT["<b>TLS-RPT</b><br/><i>RFC 8460</i>"]:::purple
        CAA["<b>CAA</b><br/><i>RFC 8659</i>"]:::purple
    end

    ICIE["<b>ICIE</b><br/><i>Intelligence Classification</i><br/><i>&amp; Interpretation Engine</i>"]:::cyan

    email --> ICIE
    transport --> ICIE
    policy --> ICIE

