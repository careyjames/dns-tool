*.out

# Source methodology PDF — regenerated by release-gate.sh via WeasyPrint.
# The static/docs/ copy is served by the app and MUST remain tracked.
docs/dns-tool-methodology.pdf

# Database files — never commit data
instance/

# Generated assets
generated-icon.png

# Git panel sync marker (agent-written, not for version control)
.gitpanel/

# Drift Cairn manifests (internal dev drift detection — local only)
# NOTE: If .drift/manifest.json shows in git status, untrack it from Shell:
#   git rm --cached .drift/manifest.json
.drift/

# SonarCloud scanner work directory (temp artifacts, binaries)
.scannerwork/

# Agent skills and internal docs — local only, never public
.agents/
.local/skills/

# Internal project documentation — development context, never public
# NOTE: If these show in git status after adding here, untrack from Shell:
#   git rm --cached EVOLUTION.md PROJECT_CONTEXT.md
EVOLUTION.md
PROJECT_CONTEXT.md

# Figma asset bundle exports — generated, not versioned
exports/

# Private repo staging — never push to public
dnstool-intel-staging/

# Intelligence boundary files — private dns-tool-intel repo only
# These files contain proprietary analysis logic and must NEVER be in the public repo.
# If they show in git status after adding here, untrack from Shell:
#   git rm --cached go-server/internal/analyzer/*_intel.go go-server/internal/analyzer/ai_surface/*_intel.go
*_intel.go

# Disposable venvs (cffconvert validation, etc.)
.venv-cff/
.venv*/

# Intel breadcrumbs — private project context, synced from dns-tool-intel
# Contains PROJECT_CONTEXT.md, EVOLUTION.md, and other operational docs
# that must never appear in the public repo.
.intel/

# Codex agent files (local tooling, not versioned)
.codex/

# Replit environment files — never commit
.replit
replit_agent.toml
.config/
.upm/
.pythonlibs/
.planning/

# Git backups (created by recovery scripts)
.git.backup*/

# Test binaries
*.test
analyzer.test

# Security scan reports — generated, not versioned
security/reports/

# Go build artifacts in subfolders
go-server/dns-tool-server
go-server/dns-tool
go-server/probe

# Compressed archives
*.tar.gz

# Inference CLI binaries
inferencesh-cli-*
